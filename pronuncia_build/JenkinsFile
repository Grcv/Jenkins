pipeline {
    agent any
    environment {
        DOCKER_USER = 'gerardocastro'
        DOCKER_REGISTRY = 'https://index.docker.io/v1/'
        DOCKER_CREDENTIALS_ID = 'dockerhub'
        TAG = "${env.BUILD_NUMBER}"
    }
    stages {

        stage("Comenzando despliegue"){
            steps{
                echo "Comenzando construccion y subida de imagenes"
            }
        }
        stage('Clonar Repositorios Secundarios') {
            steps {
                dir('pronuncia_backend_repo') {
                    git credentialsId: 'github_credentials', url: 'https://github.com/Grcv/vocab_backend.git', branch: 'main'
                }
                dir('pronuncia_frontend_repo') {
                    git credentialsId: 'github_credentials',url: 'https://github.com/Grcv/vocab_frontend.git', branch: 'main'
                }
                dir('media_files_repo') {
                    git credentialsId: 'github_credentials',url: 'https://github.com/Grcv/media_files.git', branch: 'main'
                }
            }
        }
        stage('Move files') {
            steps {
                sh '''
                    mkdir -p app/pronuncia_frontend
                    mkdir -p app/pronuncia_backend
                    cp pronuncia_build/docker-compose.yml app/
                    cp -r pronuncia_frontend_repo/vocab_app/* app/pronuncia_frontend/
                    cp -r pronuncia_backend_repo/english_vocab/* app/pronuncia_backend/
                    cp -r media_files_repo/media/ app/pronuncia_backend/
                    cp -r media_files_repo/media/csv/* app/pronuncia_backend/english_vocab/vocubulary/management/commands
                '''
            }
        }

        stage('Construir imágenes Docker') {
            steps {
                dir('app') {
                    sh 'docker compose build'
                }
            }
        }

        // stage('Login y Push a Docker Hub') {
        //     steps {
        //         dir('app') {
        //             script {
        //                 docker.withRegistry(DOCKER_REGISTRY, DOCKER_CREDENTIALS_ID) {
        //                     sh """
        //                         docker tag app-frontend ${DOCKER_USER}/aceros_frontend:latest
        //                         docker tag app-backend ${DOCKER_USER}/aceros_backend:latest
        //                         docker push ${DOCKER_USER}/aceros_frontend:latest
        //                         docker push ${DOCKER_USER}/aceros_backend:latest
        //                     """
        //                 }
        //             }
        //         }
        //     }
        // }

        stage('Levantar contenedores localmente') {
            steps {
                dir('app') {
                    sh 'docker compose up -d'
                }
            }
        }

    }
    // post {
    //     success {
    //         echo '✅ Construcción y subida a Docker Hub exitosa.'
    //         deleteDir()
    //     }
    //     failure {
    //         echo '❌ Falló la construcción o subida a Docker Hub.'
    //         deleteDir()
    //     }
    // }
    post {
        success {
            echo '✅ Despliegue local exitoso.'
            deleteDir()
        }
        failure {
            echo '❌ Falló el despliegue local.'
            deleteDir()
        }
    }
}
